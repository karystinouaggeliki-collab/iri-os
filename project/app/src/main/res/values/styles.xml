<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
    <item name="android:fontFamily">sans</item>
    <item name="android:windowActionModeOverlay">true</item>
    <item name="android:colorAccent">@color/accent</item>
  </style>

  <style name="PanelAppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
    <item name="android:fontFamily">sans</item>
    <item name="android:windowBackground">@color/panel_background</item>
    <item name="android:colorAccent">@color/accent</item>
  </style>

  <style name="ToolbarButton">
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">48dp</item>
    <item name="android:minWidth">64dp</item>
    <item name="android:layout_marginEnd">6dp</item>
    <item name="android:backgroundTint">#2A3A57</item>
    <item name="android:textColor">@color/toolbar_text</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:textSize">15sp</item>
  </style>

  <style name="BookmarkButton" parent="ToolbarButton">
    <item name="android:layout_height">42dp</item>
    <item name="android:backgroundTint">#E8EDF4</item>
    <item name="android:textColor">#25344A</item>
    <item name="android:minWidth">96dp</item>
  </style>
</resources>
